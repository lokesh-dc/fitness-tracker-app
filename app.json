{
  "expo": {
    "name": "FitTrackMobile",
    "slug": "FitTrackMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lokesh.ft.test"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#f97316"
        }
      ]
    ],
    "scheme": "fittrack",
    "android": {
      "package": "com.lokeshchoudhary.fittrackmobile"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "80023296-30ac-41d4-a83f-7890df1b705f"
      }
    }
  }
}
